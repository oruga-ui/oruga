{
  "extends": ["@tsconfig/node24/tsconfig.json", "@vue/tsconfig/tsconfig.json"],
  "compilerOptions": {
    // `vue-tsc --build` produces a .tsbuildinfo file for incremental type-checking
    // specified here to keep it out of the root directory
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.tsbuildinfo",

    // @vue/tsconfig comes with noUncheckedIndexedAccess enabled
    "noUncheckedIndexedAccess": false,

    "noImplicitAny": false,

    // vitepress includes a node and client environment
    "types": ["node", "vite/client", "vitepress/client"],

    // path mapping for cleaner imports
    "paths": {
      "@/*": ["../oruga/src/*"],
      "@docs": ["./src"],
      "@docs/*": ["./src/*"],
      "@oruga-ui/oruga-next": ["../oruga/src"]
    }
  },
  "include": [
    // include docs runtime files
    ".vitepress/**/*",
    // include docs generation files
    "src/**/*"
  ]
}
