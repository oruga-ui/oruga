{
  "extends": "@vue/tsconfig/tsconfig.json",
  "compilerOptions": {
    "allowJs": true,
    // @vue/tsconfig comes with noUncheckedIndexedAccess enabled
    "noUncheckedIndexedAccess": false,

    "types": ["node", "vite/client", "vitepress/client"],
    "paths": {
      "@docs": ["./src"],
      "@docs/*": ["./src/*"],
      "@oruga-ui/oruga-next": ["../oruga/src"]
    }
  },
  "include": [
    ".vitepress/**/*",
    "src/**/*",
    "src/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
