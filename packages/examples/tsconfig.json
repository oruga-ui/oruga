{
  "extends": "@vue/tsconfig/tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "sourceMap": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.tsbuildinfo",
    "importHelpers": true,
    "noImplicitThis": false,
    "noImplicitAny": false,
    // @vue/tsconfig comes with noUncheckedIndexedAccess enabled
    "noUncheckedIndexedAccess": false,

    "types": ["node", "vite/client"],
    "paths": {
      "@/*": ["../oruga/src/*"],
      "@oruga-ui/oruga-next": ["../oruga/src/index"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.vue",
    // include lib code
    "../oruga/src/**/*.ts",
    "../oruga/src/**/*.vue",
    // include docs components
    "../docs/.vitepress/theme/components/ExampleViewer.vue"
  ],
  "exclude": [
    // exclude docs only code
    "../oruga/src/**/inspector.vue",
    // exclude test code
    "../oruga/src/__tests__/**",
    "../oruga/src/**/*.test.ts"
  ]
}
