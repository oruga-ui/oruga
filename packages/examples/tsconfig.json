{
  "extends": "@vue/tsconfig/tsconfig.json",
  "compilerOptions": {
    // `vue-tsc --build` produces a .tsbuildinfo file for incremental type-checking
    // specified here to keep it out of the root directory
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.tsbuildinfo",

    // @vue/tsconfig comes with noUncheckedIndexedAccess enabled
    "noUncheckedIndexedAccess": false,

    "sourceMap": true,
    "importHelpers": true,
    "noImplicitAny": false,

    "types": ["node", "vite/client"],

    // path mapping for cleaner imports
    "paths": {
      "@/*": ["../oruga/src/*"],
      "@oruga-ui/oruga-next": ["../oruga/src/index"]
    }
  },
  "include": [
    "src/**/*",
    // include lib code
    "../oruga/src/**/*",
    // include docs components
    "../docs/.vitepress/theme/components/ExampleViewer.vue"
  ],
  "exclude": [
    // exclude docs only code
    "../oruga/src/**/inspector.vue",
    // exclude test code
    "../oruga/src/__tests__/**",
    "../oruga/src/**/*.test.ts"
  ]
}
