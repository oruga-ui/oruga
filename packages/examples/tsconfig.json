{
  "extends": "@vue/tsconfig/tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.tsbuildinfo",
    "importHelpers": true,
    "allowSyntheticDefaultImports": true,
    "noImplicitThis": false,
    "noImplicitAny": false,
    // @vue/tsconfig comes with noUncheckedIndexedAccess enabled
    "noUncheckedIndexedAccess": false,

    "types": ["node", "vite/client"],
    "paths": {
      "@/*": ["../oruga/src/*"],
      "@oruga-ui/oruga-next": ["../oruga/src/index"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.vue",
    "../oruga/src/**/*.ts",
    "../oruga/src/**/*.vue",
    "../docs/.vitepress/**/*.vue"
  ],
  "exclude": ["../oruga/src/__tests__/**", "../oruga/src/**/*.test.ts"]
}
