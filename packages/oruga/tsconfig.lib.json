{
  "extends": [
    "@vue/tsconfig/tsconfig.dom.json",
    "@vue/tsconfig/tsconfig.lib.json"
  ],
  "compilerOptions": {
    "composite": true,
    // `vue-tsc --build` produces a .tsbuildinfo file for incremental type-checking
    // specified here to keep it out of the root directory
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.lib.tsbuildinfo",

    // @vue/tsconfig comes with noUncheckedIndexedAccess enabled
    "noUncheckedIndexedAccess": false,

    "sourceMap": true,
    "importHelpers": true,
    "noImplicitAny": false,

    "types": ["vite/client", "./src/globals.d.ts"],

    // path mapping for cleaner imports
    "paths": {
      // Path used by lib files .
      "@/*": ["./src/*"],
      // path used by inspector files
      "@docs": ["../docs/src/types"],
      // path used by example files
      "@oruga-ui/oruga-next": ["./src/index"]
    }
  },
  "include": [
    // include lib code
    "src/**/*",
    "src/**/*.ts",
    "src/**/*.d.ts",
    "src/**/*.vue",
    // include docs types
    "../docs/src/types.ts"
  ],
  "exclude": [
    // exclude test code
    "src/**/__tests__/*",
    "src/**/*.test.ts"
  ]
}
