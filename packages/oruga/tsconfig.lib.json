{
  "extends": [
    "@vue/tsconfig/tsconfig.dom.json",
    "@vue/tsconfig/tsconfig.lib.json"
  ],
  "compilerOptions": {
    "composite": true,
    "sourceMap": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.lib.tsbuildinfo",
    "importHelpers": true,
    "noImplicitThis": false,
    "noImplicitAny": false,
    // @vue/tsconfig comes with noUncheckedIndexedAccess enabled
    "noUncheckedIndexedAccess": false,

    "types": ["vite/client", "./volar.d.ts"],
    "paths": {
      "@/*": ["./src/*"],
      "@oruga-ui/oruga-next": ["./src/index"],
      "@docs": ["../docs/src/types"]
    }
  },
  "include": [
    // include lib code
    "src/**/*",
    "src/**/*.ts",
    "src/**/*.d.ts",
    "src/**/*.vue",
    // include docs types
    "../docs/src/types.ts"
  ],
  "exclude": [
    // exclude test code
    "src/**/__tests__/*",
    "src/**/*.test.ts"
  ]
}
