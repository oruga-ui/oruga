{
  "extends": "./tsconfig.lib.json",
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.vitest.tsbuildinfo",
    "skipLibCheck": true,

    // override types with node extension
    "types": ["node", "jsdom", "vite/client"]
  },
  "exclude": [
    // exclude examples code
    "src/**/examples/*",
  ]
}
